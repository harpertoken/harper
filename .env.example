# Harper environment template

# Copy to `.env` and fill in only the provider you plan to use.

# OpenAI
# OPENAI_API_KEY=sk-your-openai-key

# Sambanova
# SAMBASTUDIO_API_KEY=your-sambanova-key

# Google Gemini
# GEMINI_API_KEY=your-gemini-key

# Ollama (local/offline)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# Optional overrides
# DATABASE_PATH=./harper.db
